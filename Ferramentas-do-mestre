<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ferramentas do Mestre</title>

  <style>
    body {
      background: #000;
      color: white;
      font-family: Arial;
      text-align: center;
      padding: 30px;
    }

    /* LOGO */
    .logo {
      width: 120px;
      margin-bottom: 15px;
    }

    /* TÍTULO */
    h1 {
      color: #ff3b3b;
      margin-bottom: 25px;
    }

    /* CARD BASE (pra você usar depois) */
    .card {
      background: #111;
      border: 1px solid #ff3b3b;
      padding: 20px;
      border-radius: 12px;
      display: inline-block;
      margin: 15px;
    }

    a {
      display: inline-block;
      margin-top: 10px;
      background: #ff3b3b;
      color: black;
      padding: 10px 15px;
      text-decoration: none;
      border-radius: 8px;
      font-weight: bold;
    }

    a:hover {
      background: #cc2f2f;
    }
  </style>
</head>

<body>

  <!-- LOGO -->
  <img src="redlogo.webp" alt="Logo" class="logo">

  <!-- TÍTULO -->
  <h1>Ferramentas do Mestre</h1>

  <!-- (SEM CARDS POR ENQUANTO) -->

</body>
</html>
